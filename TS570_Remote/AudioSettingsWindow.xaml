<Window x:Class="TS570_Remote.AudioSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audio — ACC2 / USB"
        Height="520" Width="540"
        MinHeight="460" MinWidth="480"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF16161C">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Text="As in WSJT-X: Input = radio to PC; Output (monitor) = where you listen on the PC; Output (TX / MIC) = USB playback toward the radio for transmit."
                   Foreground="#FFFFB040" FontFamily="Consolas" FontSize="10" TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <TextBlock Grid.Row="1" Text="Input — capture (recording)"
                   Foreground="#FFE0E0E8" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="2"
                   Text="USB / line from ACC2 (RX audio into Windows)."
                   Foreground="#FF8A8A96" FontFamily="Consolas" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,8"/>
        <ComboBox x:Name="cmbCapture"
                  Grid.Row="3"
                  FontFamily="Consolas" FontSize="10"
                  Margin="0,0,0,14"
                  DisplayMemberPath="FriendlyName"/>

        <TextBlock Grid.Row="4" Text="Output — monitor playback (PHONES knob)"
                   Foreground="#FFE0E0E8" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="5"
                   Text="Speakers or headphones for ACC2 monitoring (software gain on this path only)."
                   Foreground="#FF8A8A96" FontFamily="Consolas" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,8"/>
        <ComboBox x:Name="cmbPlayback"
                  Grid.Row="6"
                  VerticalAlignment="Top"
                  FontFamily="Consolas" FontSize="10"
                  Margin="0,0,0,14"
                  DisplayMemberPath="FriendlyName"/>

        <TextBlock Grid.Row="7" Text="Output — transmit path (MIC knob → Windows volume)"
                   Foreground="#FFE0E0E8" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="8"
                   Text="The WSJT-X-style Speakers (USB…) endpoint: master level toward the radio, without lowering capture input or monitor level."
                   Foreground="#FF8A8A96" FontFamily="Consolas" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,8"/>
        <ComboBox x:Name="cmbTxPlayback"
                  Grid.Row="9"
                  VerticalAlignment="Top"
                  FontFamily="Consolas" FontSize="10"
                  DisplayMemberPath="FriendlyName"/>

        <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK" Width="90" Height="26" Margin="0,0,8,0" IsDefault="True" Click="BtnOk_Click"/>
            <Button Content="Cancel" Width="90" Height="26" IsCancel="True" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
