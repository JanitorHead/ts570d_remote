<Window x:Class="TS570_Remote.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Kenwood TS-570D Remote Control"
        Height="440" Width="1120"
        MinHeight="280" MinWidth="800"
        ResizeMode="CanResize"
        Background="#FF0E0E14">

    <!--
    DSEG7 Classic (free): https://github.com/keshikan/DSEG
    Embedded font: Resources/Fonts/DSEG7Classic-BoldItalic.ttf  (Build Action = Resource)
    FontFamily: pack://application:,,,/Resources/Fonts/DSEG7Classic-BoldItalic.ttf#DSEG7 Classic
    -->

    <Window.Resources>

        <!-- ══ BASE METALLIC BUTTON ══════════════════════════════════════════ -->
        <Style x:Key="MetalBtn" TargetType="Button">
            <Setter Property="Foreground"          Value="#FFD2D2D8"/>
            <Setter Property="FontFamily"          Value="Consolas"/>
            <Setter Property="FontSize"            Value="9.5"/>
            <Setter Property="FontWeight"          Value="Bold"/>
            <Setter Property="Cursor"              Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="3" BorderThickness="1"
                                SnapsToDevicePixels="True">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF626268" Offset="0"/>
                                    <GradientStop Color="#FF26262E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF5A5A62" Offset="0"/>
                                    <GradientStop Color="#FF404048" Offset="0.45"/>
                                    <GradientStop Color="#FF30303A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="2"
                                                  ShadowDepth="1.5" Opacity="0.65" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" Margin="4,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF1A1A22" Offset="0"/>
                                            <GradientStop Color="#FF2A2A34" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF8888B8" Offset="0"/>
                                            <GradientStop Color="#FF404068" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource MetalBtn}"/>

        <Style x:Key="PowerBtn" TargetType="Button" BasedOn="{StaticResource MetalBtn}">
            <Setter Property="Foreground" Value="#FFFF4444"/>
        </Style>
        <Style x:Key="OrangeBtn" TargetType="Button" BasedOn="{StaticResource MetalBtn}">
            <Setter Property="Foreground" Value="#FFFF9200"/>
        </Style>

        <!-- ══ PILL - left function buttons (label shown above) ═════════════ -->
        <Style x:Key="PillBtn" TargetType="Button" BasedOn="{StaticResource MetalBtn}">
            <Setter Property="Height"    Value="20"/>
            <Setter Property="MinWidth"  Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="10" BorderThickness="1"
                                SnapsToDevicePixels="True">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF626268" Offset="0"/>
                                    <GradientStop Color="#FF26262E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF5A5A62" Offset="0"/>
                                    <GradientStop Color="#FF404048" Offset="0.45"/>
                                    <GradientStop Color="#FF30303A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="2"
                                                  ShadowDepth="1.5" Opacity="0.65" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" Margin="4,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF1A1A22" Offset="0"/>
                                            <GradientStop Color="#FF2A2A34" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF8888B8" Offset="0"/>
                                            <GradientStop Color="#FF404068" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Red pill variant for POWER -->
        <Style x:Key="PillPowerBtn" TargetType="Button" BasedOn="{StaticResource PillBtn}">
            <Setter Property="Foreground" Value="#FFFF4444"/>
        </Style>

        <!-- Round button style for PF -->
        <Style x:Key="RoundBtn" TargetType="Button" BasedOn="{StaticResource MetalBtn}">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="10" BorderThickness="1"
                                SnapsToDevicePixels="True">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF626268" Offset="0"/>
                                    <GradientStop Color="#FF26262E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF5A5A62" Offset="0"/>
                                    <GradientStop Color="#FF404048" Offset="0.45"/>
                                    <GradientStop Color="#FF30303A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="2"
                                                  ShadowDepth="1.5" Opacity="0.65" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF1A1A22" Offset="0"/>
                                            <GradientStop Color="#FF2A2A34" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF8888B8" Offset="0"/>
                                            <GradientStop Color="#FF404068" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Round button style for VFO keys -->
        <Style x:Key="RoundVfoBtn" TargetType="Button" BasedOn="{StaticResource MetalBtn}">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="23" BorderThickness="1"
                                SnapsToDevicePixels="True">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF626268" Offset="0"/>
                                    <GradientStop Color="#FF26262E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF5A5A62" Offset="0"/>
                                    <GradientStop Color="#FF404048" Offset="0.45"/>
                                    <GradientStop Color="#FF30303A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="2"
                                                  ShadowDepth="1.5" Opacity="0.65" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" Margin="3"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF1A1A22" Offset="0"/>
                                            <GradientStop Color="#FF2A2A34" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF8888B8" Offset="0"/>
                                            <GradientStop Color="#FF404068" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small round button style for MIC / PWR / KEY / DLY -->
        <Style x:Key="RoundMiniBtn" TargetType="Button" BasedOn="{StaticResource MetalBtn}">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="15" BorderThickness="1"
                                SnapsToDevicePixels="True">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF626268" Offset="0"/>
                                    <GradientStop Color="#FF26262E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF5A5A62" Offset="0"/>
                                    <GradientStop Color="#FF404048" Offset="0.45"/>
                                    <GradientStop Color="#FF30303A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="2"
                                                  ShadowDepth="1.5" Opacity="0.65" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF1A1A22" Offset="0"/>
                                            <GradientStop Color="#FF2A2A34" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF8888B8" Offset="0"/>
                                            <GradientStop Color="#FF404068" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Light gray variants for specific control groups -->
        <Style x:Key="LightRoundVfoBtn" TargetType="Button" BasedOn="{StaticResource RoundVfoBtn}">
            <Setter Property="Foreground" Value="#FFE8E8EE"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="23" BorderThickness="1" SnapsToDevicePixels="True">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFB9BBC6" Offset="0"/>
                                    <GradientStop Color="#FF737988" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFA7ADBC" Offset="0"/>
                                    <GradientStop Color="#FF8E95A6" Offset="0.45"/>
                                    <GradientStop Color="#FF7A8192" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="1.5" Opacity="0.5" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="3"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF6E7484" Offset="0"/>
                                            <GradientStop Color="#FF838A9C" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LightRoundMiniBtn" TargetType="Button" BasedOn="{StaticResource RoundMiniBtn}">
            <Setter Property="Foreground" Value="#FFE8E8EE"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="15" BorderThickness="1" SnapsToDevicePixels="True">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFB9BBC6" Offset="0"/>
                                    <GradientStop Color="#FF737988" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFA7ADBC" Offset="0"/>
                                    <GradientStop Color="#FF8E95A6" Offset="0.45"/>
                                    <GradientStop Color="#FF7A8192" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="1.5" Opacity="0.5" Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF6E7484" Offset="0"/>
                                            <GradientStop Color="#FF838A9C" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ LCD BADGE: status indicator ══════════════════════════════════ -->
        <!-- Dark amber LCD text appearance -->
        <Style x:Key="LcdBadge" TargetType="Border">
            <Setter Property="Background"    Value="#30180800"/>
            <Setter Property="CornerRadius"  Value="2"/>
            <Setter Property="Padding"       Value="5,1.5"/>
            <Setter Property="Margin"        Value="0,0,5,0"/>
            <Setter Property="Visibility"    Value="Collapsed"/>
        </Style>
        <Style x:Key="LcdBadgeText" TargetType="TextBlock">
            <Setter Property="FontFamily"   Value="Consolas"/>
            <Setter Property="FontSize"     Value="9.5"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Foreground"   Value="#FF180800"/>
        </Style>

        <!-- ══ LEDs ═════════════════════════════════════════════════════════ -->
        <Style x:Key="LedGreen" TargetType="Ellipse">
            <Setter Property="Width"  Value="9"/>
            <Setter Property="Height" Value="9"/>
            <Setter Property="Fill">
                <Setter.Value>
                    <RadialGradientBrush>
                        <GradientStop Color="#FF88FF88" Offset="0"/>
                        <GradientStop Color="#FF00BB00" Offset="1"/>
                    </RadialGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FF00FF00" BlurRadius="5" ShadowDepth="0" Opacity="0.8"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LedAmber" TargetType="Ellipse">
            <Setter Property="Width"  Value="9"/>
            <Setter Property="Height" Value="9"/>
            <Setter Property="Fill">
                <Setter.Value>
                    <RadialGradientBrush>
                        <GradientStop Color="#FFFFC840" Offset="0"/>
                        <GradientStop Color="#FFCC8000" Offset="1"/>
                    </RadialGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#FFFFAA00" BlurRadius="5" ShadowDepth="0" Opacity="0.8"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ Potentiometer brushes ═════════════════════════════════════════ -->
        <RadialGradientBrush x:Key="KnobFace">
            <GradientStop Color="#FF4C4C56" Offset="0"/>
            <GradientStop Color="#FF2A2A36" Offset="0.75"/>
            <GradientStop Color="#FF1A1A26" Offset="1"/>
        </RadialGradientBrush>
        <RadialGradientBrush x:Key="KnobInner">
            <GradientStop Color="#FF565662" Offset="0"/>
            <GradientStop Color="#FF32323E" Offset="1"/>
        </RadialGradientBrush>
        <LinearGradientBrush x:Key="KnobRim" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF5A5A64" Offset="0"/>
            <GradientStop Color="#FF1A1A26" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="UiTextWhite" Color="#FFF0F0F4"/>
        <SolidColorBrush x:Key="UiTextGray" Color="#FF8A8A96"/>
        <SolidColorBrush x:Key="UiTextOrange" Color="#FFFF9200"/>

    </Window.Resources>

    <Viewbox Stretch="Uniform">
        <!-- ════════════════════════════════════════════════════════════════════
         MAIN CHASSIS  1120 × 440
         ════════════════════════════════════════════════════════════════════ -->
        <Border Width="1120" Height="440" CornerRadius="8" BorderThickness="2.5">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF6E6E78" Offset="0"/>
                    <GradientStop Color="#FF1C1C28" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF3E3E4A" Offset="0"/>
                    <GradientStop Color="#FF2A2A36" Offset="0.5"/>
                    <GradientStop Color="#FF222230" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="8" Opacity="0.95"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="176"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="34"/>
                </Grid.RowDefinitions>

                <!-- ══ TITLE BAR ═══════════════════════════════════════════════ -->
                <Border Grid.Row="0" CornerRadius="6,6,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FF141420" Offset="0"/>
                            <GradientStop Color="#FF1E1E2C" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <DockPanel Margin="12,0,12,0" VerticalAlignment="Center">
                        <Button x:Name="btnSynchronize" DockPanel.Dock="Right"
                            Content="Synchronize" Style="{StaticResource OrangeBtn}"
                            Width="100" Height="22" Click="btnSynchronize_Click"/>
                        <TextBlock Text="REMOTE  •  HF TRANSCEIVER  •  TS-570D"
                               FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                               Foreground="#FFCACAD2" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- ══ ROW 1 - LCD ═════════════════════════════════════════════ -->
                <Grid Grid.Row="1" Margin="5,4,5,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="115"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="128"/>
                    </Grid.ColumnDefinitions>

                    <!-- ══════════════════════════════════════════════════════════
                         Eight left function buttons - pill shape with top labels
                         ══════════════════════════════════════════════════════════ -->
                    <UniformGrid Grid.Column="0" Rows="4" Columns="2" Margin="0">

                        <StackPanel Margin="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="PF"
                                       Foreground="#FFB0B0BC" FontFamily="Consolas" FontSize="8" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,3"/>
                            <Button x:Name="btnPf" Style="{StaticResource RoundBtn}"
                                    HorizontalAlignment="Center" Click="btnPf_Click"/>
                        </StackPanel>

                        <StackPanel Margin="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="POWER"
                                       Foreground="#FFFF6666" FontFamily="Consolas" FontSize="8" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,3"/>
                            <Button x:Name="btnPower" Style="{StaticResource PillPowerBtn}"
                                    HorizontalAlignment="Stretch" Click="btnPower_Click"/>
                        </StackPanel>

                        <StackPanel Margin="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="ATT"
                                       Foreground="#FFB0B0BC" FontFamily="Consolas" FontSize="8" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,3"/>
                            <Button x:Name="btnAtt" Style="{StaticResource PillBtn}"
                                    HorizontalAlignment="Stretch" Click="btnAtt_Click"/>
                        </StackPanel>

                        <StackPanel Margin="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="PRE-AMP"
                                       Foreground="#FFB0B0BC" FontFamily="Consolas" FontSize="8" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,3"/>
                            <Button x:Name="btnPreAmp" Style="{StaticResource PillBtn}"
                                    HorizontalAlignment="Stretch" Click="btnPreAmp_Click"/>
                        </StackPanel>

                        <StackPanel Margin="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="VOX"
                                       Foreground="#FFB0B0BC" FontFamily="Consolas" FontSize="8" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,3"/>
                            <Button x:Name="btnVox" Style="{StaticResource PillBtn}"
                                    HorizontalAlignment="Stretch" Click="btnVox_Click"/>
                        </StackPanel>

                        <StackPanel Margin="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="PROC"
                                       Foreground="#FFB0B0BC" FontFamily="Consolas" FontSize="8" FontWeight="Bold"
