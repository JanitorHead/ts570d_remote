                        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="MIC"
                                   Foreground="{StaticResource UiTextGray}" FontFamily="Consolas" FontSize="8.5"
                                   HorizontalAlignment="Center" Margin="0,0,0,2"/>

                        <Border x:Name="meterMicTrack"
                                Grid.Row="3" Grid.Column="0"
                                Width="10" Height="52"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                CornerRadius="2"
                                Background="#15151C"
                                BorderBrush="#383848"
                                BorderThickness="1"
                                SnapsToDevicePixels="True">
                            <Border ClipToBounds="True" CornerRadius="2">
                                <Rectangle x:Name="meterMicFill"
                                           Fill="#FFFF9200"
                                           VerticalAlignment="Bottom"
                                           HorizontalAlignment="Stretch"
                                           Height="0"/>
                            </Border>
                        </Border>

                        <Grid Grid.Row="3" Grid.Column="1"
                              HorizontalAlignment="Center" Width="52" Height="52"
                              MouseWheel="MicGainKnob_MouseWheel" PreviewMouseWheel="MicGainKnob_MouseWheel"
                              MouseLeftButtonDown="MicGainKnob_MouseLeftButtonDown" MouseMove="MicGainKnob_MouseMove" MouseLeftButtonUp="MicGainKnob_MouseLeftButtonUp">
                            <Grid RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <RotateTransform x:Name="rtMicGain" Angle="0"/>
                                </Grid.RenderTransform>
                                <Ellipse StrokeThickness="2">
                                    <Ellipse.Fill>
                                        <StaticResource ResourceKey="KnobFace"/>
                                    </Ellipse.Fill>
                                    <Ellipse.Stroke>
                                        <StaticResource ResourceKey="KnobRim"/>
                                    </Ellipse.Stroke>
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="2" Opacity="0.7"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <Ellipse Width="20" Height="20">
                                    <Ellipse.Fill>
                                        <StaticResource ResourceKey="KnobInner"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <Rectangle Width="3.5" Height="16" RadiusX="1.5" RadiusY="1.5" Fill="#FFBCBCCA"
                                           VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- COL 1: NUMERIC GRID (12 round buttons + labels) -->
                    <Grid Grid.Column="1" Margin="0,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Margin="1,0">
                            <TextBlock Text="CH1" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <Button Content="1" Style="{StaticResource RoundVfoBtn}" Width="36" Height="36" FontSize="14" Click="btnKey1_Click"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Margin="1,0">
                            <TextBlock Text="CH2" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <Button Content="2" Style="{StaticResource RoundVfoBtn}" Width="36" Height="36" FontSize="14" Click="btnKey2_Click"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center" Margin="1,0">
                            <TextBlock Text="CH3" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <Button x:Name="btnFine" Content="3" Style="{StaticResource RoundVfoBtn}" Width="36" Height="36" FontSize="14" Click="btnKey3_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" Margin="1,0">
                            <TextBlock Text="ANT" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <Button x:Name="btnNB" Content="4" Style="{StaticResource RoundVfoBtn}" Width="36" Height="36" FontSize="14" Click="btnKey4_Click"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" Margin="1,0">
                            <TextBlock Text="REC" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <Button x:Name="btnAGC" Content="5" Style="{StaticResource RoundVfoBtn}" Width="36" Height="36" FontSize="14" Click="btnKey5_Click"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" Margin="1,0">
                            <TextBlock Text="FINE" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <Button Content="6" Style="{StaticResource RoundVfoBtn}" Width="36" Height="36" FontSize="14" Click="btnKey6_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center" Margin="1,0">
                            <TextBlock Text="NB" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <Button Content="7" Style="{StaticResource RoundVfoBtn}" Width="36" Height="36" FontSize="14" Click="btnKey7_Click"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" Margin="1,0">
                            <TextBlock Text="AGC/TONE" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.5" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <Button Content="8" Style="{StaticResource RoundVfoBtn}" Width="36" Height="36" FontSize="14" Click="btnKey8_Click"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2" HorizontalAlignment="Center" Margin="1,0">
                            <TextBlock Text="REV" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <Button Content="9" Style="{StaticResource RoundVfoBtn}" Width="36" Height="36" FontSize="14" Click="btnKey9_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0" HorizontalAlignment="Center" Margin="1,0">
                            <TextBlock Text="" FontSize="7.8" Margin="0,0,0,2"/>
                            <Button Content="CLR" Style="{StaticResource RoundVfoBtn}" Width="36" Height="36" FontSize="9" Click="btnKeyCLR_Click"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="1" HorizontalAlignment="Center" Margin="1,0">
                            <TextBlock Text="F.LOCK" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                            <Button Content="0" Style="{StaticResource RoundVfoBtn}" Width="36" Height="36" FontSize="14" Click="btnKey0_Click"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="2" HorizontalAlignment="Center" Margin="1,0">
                            <TextBlock Text="" FontSize="7.8" Margin="0,0,0,2"/>
                            <Button Content="ENT" Style="{StaticResource RoundVfoBtn}" Width="36" Height="36" FontSize="9" Click="btnKeyENT_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- COL 2: MIC / PWR / KEY / DELAY -->
                    <StackPanel Grid.Column="2" Orientation="Vertical" Margin="0,0,0,0" VerticalAlignment="Top">
                        <StackPanel Orientation="Vertical" Margin="0,3" HorizontalAlignment="Center">
                            <TextBlock Text="MIC" Foreground="{StaticResource UiTextOrange}" FontFamily="Consolas" FontSize="7" HorizontalAlignment="Center"/>
                            <Button x:Name="btnMic" Style="{StaticResource RoundMiniBtn}" Click="btnMic_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Margin="0,3" HorizontalAlignment="Center">
                            <TextBlock Text="PWR" Foreground="{StaticResource UiTextOrange}" FontFamily="Consolas" FontSize="7" HorizontalAlignment="Center"/>
                            <Button x:Name="btnPwr" Style="{StaticResource RoundMiniBtn}" Click="btnPwr_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Margin="0,3" HorizontalAlignment="Center">
                            <TextBlock Text="KEY" Foreground="{StaticResource UiTextOrange}" FontFamily="Consolas" FontSize="7" HorizontalAlignment="Center"/>
                            <Button x:Name="btnKey" Style="{StaticResource RoundMiniBtn}" Click="btnKey_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Margin="0,3" HorizontalAlignment="Center">
                            <TextBlock Foreground="{StaticResource UiTextOrange}" FontFamily="Consolas" FontSize="7" HorizontalAlignment="Center"><Run Text="D"/><Run Text="E"/><Run Text="L"/><Run Language="en-gb" Text="A"/><Run Text="Y"/></TextBlock>
                            <Button x:Name="btnDelay" Style="{StaticResource RoundMiniBtn}" Click="btnDelay_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- COL 3: MODES -->
                    <StackPanel Grid.Column="3" Orientation="Vertical" Margin="0,0,0,0" VerticalAlignment="Top">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,2,0,4">
                            <Button x:Name="btnLsbUsb" Style="{StaticResource LightRoundMiniBtn}" Width="30" Height="30" Margin="0,2" Click="btnLsbUsb_Click">
                                <Button.Content>
                                    <TextBlock Text="LSB&#10;USB" TextAlignment="Center" FontSize="7" FontWeight="Bold" LineHeight="7.5"/>
                                </Button.Content>
                            </Button>
                            <Button x:Name="btnCwFsk" Style="{StaticResource LightRoundMiniBtn}" Width="30" Height="30" Margin="0,2" Click="btnCwFsk_Click">
                                <Button.Content>
                                    <TextBlock Text="CW&#10;FSK" TextAlignment="Center" FontSize="7" FontWeight="Bold" LineHeight="7.5"/>
                                </Button.Content>
                            </Button>
                            <Button x:Name="btnFmAm" Style="{StaticResource LightRoundMiniBtn}" Width="30" Height="30" Margin="0,2" Click="btnFmAm_Click">
                                <Button.Content>
                                    <TextBlock Text="FM&#10;AM" TextAlignment="Center" FontSize="7" FontWeight="Bold" LineHeight="7.5"/>
                                </Button.Content>
                            </Button>
                        </StackPanel>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="MENU" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.2" FontWeight="Bold"
                                           HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                <Button x:Name="btnMenu" Style="{StaticResource RoundMiniBtn}" Width="30" Height="30" Click="btnMenu_Click"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="1MHz" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.2" FontWeight="Bold"
                                           HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                <Button x:Name="btn1MHz" Style="{StaticResource RoundMiniBtn}" Width="30" Height="30" Click="btn1MHz_Click"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- COL 4: KNOB VFO -->
                    <StackPanel Grid.Column="4" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-10,0,0">
                        <!-- Internal controls kept for compatibility -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0" Visibility="Collapsed">
                            <Button x:Name="btnStepDown" Content="&lt;" Margin="2,2" Width="30" Height="26" FontSize="15" FontWeight="Bold" Click="btnStepDown_Click"/>
                            <TextBlock x:Name="txtTuneStep" Text="1 kHz" FontFamily="Consolas" FontSize="10.5" Foreground="#FFAAAABC" VerticalAlignment="Center" Margin="4,0" MinWidth="48" TextAlignment="Center"/>
                            <Button x:Name="btnStepUp" Content="&gt;" Margin="2,2" Width="30" Height="26" FontSize="15" FontWeight="Bold" Click="btnStepUp_Click"/>
                        </StackPanel>
                        <Grid Width="176" Height="176"
                              MouseWheel="VfoMainKnob_MouseWheel" PreviewMouseWheel="VfoMainKnob_MouseWheel"
                              MouseLeftButtonDown="VfoMainKnob_MouseLeftButtonDown" MouseMove="VfoMainKnob_MouseMove" MouseLeftButtonUp="VfoMainKnob_MouseLeftButtonUp">
                            <Ellipse StrokeThickness="4">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#FF3A3A46" Offset="0.55"/>
                                        <GradientStop Color="#FF262632" Offset="0.76"/>
                                        <GradientStop Color="#FF1A1A24" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Stroke>
                                    <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                                        <GradientStop Color="#FF878792" Offset="0"/>
                                        <GradientStop Color="#FF2A2A36" Offset="0.55"/>
                                        <GradientStop Color="#FF6C6C78" Offset="1"/>
                                    </LinearGradientBrush>
                                </Ellipse.Stroke>
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="4" Opacity="0.88"/>
                                </Ellipse.Effect>
                            </Ellipse>

                            <Grid RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <RotateTransform x:Name="rtVfoMain" Angle="0"/>
                                </Grid.RenderTransform>
                                <Ellipse Width="150" Height="150" StrokeThickness="2">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush Center="0.38,0.34" GradientOrigin="0.34,0.28">
                                            <GradientStop Color="#FF5A5A66" Offset="0"/>
                                            <GradientStop Color="#FF3E3E4A" Offset="0.58"/>
                                            <GradientStop Color="#FF242430" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                    <Ellipse.Stroke>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF6A6A74" Offset="0"/>
                                            <GradientStop Color="#FF181820" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Ellipse.Stroke>
                                </Ellipse>

                                <!-- Finger indentation (no linear marker) -->
                                <Ellipse Width="48" Height="48" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,48,0,0">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush Center="0.28,0.28" GradientOrigin="0.25,0.25">
                                            <GradientStop Color="#FF6D6D78" Offset="0"/>
                                            <GradientStop Color="#FF444451" Offset="0.55"/>
                                            <GradientStop Color="#FF2A2A36" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                    <Ellipse.Stroke>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#8050505A" Offset="0"/>
                                            <GradientStop Color="#4016161E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Ellipse.Stroke>
                                </Ellipse>

                                <Ellipse Width="150" Height="150" StrokeThickness="0.6" Stroke="#22FFFFFF" Fill="Transparent"/>
                            </Grid>
                        </Grid>
                    </StackPanel>

                    <!-- COL 5: DOWN/UP + QUICK MEMO + SPLIT BUTTONS -->
                    <StackPanel Grid.Column="5" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="6,-10,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,3">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="2,0">
                                <TextBlock Text="DOWN" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.5" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                <Button x:Name="btnFreqDown" Style="{StaticResource LightRoundVfoBtn}" Width="34" Height="34" Click="btnFreqDown_Click">
                                    <Button.Content>
                                        <Grid>
                                            <Border Width="24" Height="4" CornerRadius="2"
                                                   Background="#33FFFFFF"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="-2,-2,0,0"/>
                                            <Border Width="24" Height="4" CornerRadius="2"
                                                   Background="#B3000000"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="2,2,0,0"/>
                                            <Border Width="24" Height="4" CornerRadius="2"
                                                   Background="#FF09090F"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button.Content>
                                </Button>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="2,0">
                                <TextBlock Text="UP" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.5" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                <Button x:Name="btnFreqUp" Style="{StaticResource LightRoundVfoBtn}" Width="34" Height="34" Click="btnFreqUp_Click">
                                    <Button.Content>
                                        <Grid>
                                            <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-2,-2,0,0">
                                                <Border Width="24" Height="4" CornerRadius="2" Background="#33FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Border Width="4" Height="24" CornerRadius="2" Background="#33FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,2,0,0">
                                                <Border Width="24" Height="4" CornerRadius="2" Background="#B3000000" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Border Width="4" Height="24" CornerRadius="2" Background="#B3000000" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border Width="24" Height="4" CornerRadius="2" Background="#FF09090F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Border Width="4" Height="24" CornerRadius="2" Background="#FF09090F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Grid>
                                    </Button.Content>
                                </Button>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="1,0,1,0">
                                <TextBlock Text="MR" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.5" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                <Button x:Name="btnQmMR" Style="{StaticResource RoundVfoBtn}" Width="28" Height="28" FontSize="8" Content="" Click="btnQmMR_Click"/>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="1,0,1,0">
                                <TextBlock Text="" FontSize="8" Margin="0,0,0,2"/>
                                <Button x:Name="btnQmMIn" Style="{StaticResource RoundVfoBtn}" Width="28" Height="28" FontSize="7.5" Content="" Click="btnQmMIn_Click"/>
                                <TextBlock Text="M.IN" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.5" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- Kept for compatibility -->
                        <StackPanel Orientation="Horizontal" Visibility="Collapsed">
                            <Button x:Name="btnQmPlus" Content="+" Click="btnQmPlus_Click"/>
                            <Button x:Name="btnQmMinus" Content="-" Click="btnQmMinus_Click"/>
                        </StackPanel>
                        <UniformGrid Rows="1" Columns="4" HorizontalAlignment="Center" Margin="0,0,0,3">
                            <Button x:Name="btnSplit" Content="SPLIT" Style="{StaticResource LightRoundVfoBtn}" Width="36" Height="36" Margin="1,1" FontSize="8" Click="btnSplit_Click"/>
                            <Button x:Name="btnTfSet" Content="TF-set" Style="{StaticResource LightRoundVfoBtn}" Width="36" Height="36" Margin="1,1" FontSize="7.5" Click="btnTfSet_Click" PreviewMouseLeftButtonDown="btnTfSet_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="btnTfSet_PreviewMouseLeftButtonUp"/>
                            <Button x:Name="btnAB" Content="A / B" Style="{StaticResource LightRoundVfoBtn}" Width="36" Height="36" Margin="1,1" FontSize="8" Click="btnAB_Click"/>
                            <Button x:Name="btnRit" Content="RIT" Style="{StaticResource LightRoundVfoBtn}" Width="36" Height="36" Margin="1,1" FontSize="8" Click="btnRit_Click"/>
                        </UniformGrid>
                        <UniformGrid Rows="1" Columns="4" HorizontalAlignment="Center" Margin="0,0,0,3">
                            <Button x:Name="btnMV" Content="M / V" Style="{StaticResource LightRoundVfoBtn}" Width="36" Height="36" Margin="1,1" FontSize="8" Click="btnMV_Click"/>
                            <Button x:Name="btnAeqB" Content="A = B" Style="{StaticResource LightRoundVfoBtn}" Width="36" Height="36" Margin="1,1" FontSize="7.5" Click="btnAeqB_Click"/>
                            <Button x:Name="btnCLS" Content="CLS" Style="{StaticResource LightRoundVfoBtn}" Width="36" Height="36" Margin="1,1" FontSize="8" Click="btnCLS_Click"/>
                            <Button x:Name="btnXit" Content="XIT" Style="{StaticResource LightRoundVfoBtn}" Width="36" Height="36" Margin="1,1" FontSize="8" Click="btnXit_Click"/>
                        </UniformGrid>
                        <UniformGrid Rows="1" Columns="3" HorizontalAlignment="Center">
                            <Button x:Name="btnScan" Content="SCAN" Style="{StaticResource PillBtn}" Margin="0,2,3,2" FontSize="8.5" Padding="6,3" Click="btnScan_Click"/>
                            <Button x:Name="btnMVfo" Content="M&gt;VFO" Style="{StaticResource PillBtn}" Margin="3,2,3,2" FontSize="8.5" Padding="6,3" Click="btnMVfo_Click"/>
                            <Button x:Name="btnMIn" Content="M.IN" Style="{StaticResource PillBtn}" Margin="3,2,0,2" FontSize="8.5" Padding="6,3" Click="btnMIn_Click"/>
                        </UniformGrid>
                    </StackPanel>

                    <!-- COL 6: 2x2 POTENTIOMETERS -->
                    <Grid Grid.Column="6" Margin="2,4,2,4" Width="220" HorizontalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Margin="0">
                            <TextBlock Text="RIT / XIT" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="8.2" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                            <Grid HorizontalAlignment="Center" Width="63" Height="63" Margin="0,0,0,4"
                                  MouseWheel="RitXitKnob_MouseWheel" PreviewMouseWheel="RitXitKnob_MouseWheel"
                                  MouseLeftButtonDown="RitXitKnob_MouseLeftButtonDown" MouseMove="RitXitKnob_MouseMove" MouseLeftButtonUp="RitXitKnob_MouseLeftButtonUp">
                                <Grid RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <RotateTransform x:Name="rtRitXit" Angle="0"/>
                                    </Grid.RenderTransform>
                                    <Ellipse StrokeThickness="2">
                                        <Ellipse.Fill>
                                            <StaticResource ResourceKey="KnobFace"/>
                                        </Ellipse.Fill>
                                        <Ellipse.Stroke>
                                            <StaticResource ResourceKey="KnobRim"/>
                                        </Ellipse.Stroke>
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.7"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <Rectangle Width="2.6" Height="11" RadiusX="1.2" RadiusY="1.2"
                                               Fill="#FFF0F0F4" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </Grid>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Margin="0">
                            <TextBlock Text="AF  ◉  RF" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="8.2" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                            <Grid HorizontalAlignment="Center" Width="72" Height="72" Margin="0,0,0,4">
                                <Grid RenderTransformOrigin="0.5,0.5"
                                      MouseWheel="AfRfOuterKnob_MouseWheel" PreviewMouseWheel="AfRfOuterKnob_MouseWheel"
                                      MouseLeftButtonDown="AfRfOuterKnob_MouseLeftButtonDown" MouseMove="AfRfOuterKnob_MouseMove" MouseLeftButtonUp="AfRfOuterKnob_MouseLeftButtonUp">
                                    <Grid.RenderTransform>
                                        <RotateTransform x:Name="rtAfRfOuter" Angle="0"/>
                                    </Grid.RenderTransform>
                                    <Ellipse StrokeThickness="2">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#FF444452" Offset="0.45"/>
                                                <GradientStop Color="#FF20202E" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                        <Ellipse.Stroke>
                                            <StaticResource ResourceKey="KnobRim"/>
                                        </Ellipse.Stroke>
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.7"/>
