                        <TextBlock x:Name="txtStatusRight"
                               Text="  ---"
                               FontFamily="Consolas" FontSize="8.5"
                               Foreground="#FF646472" Margin="0,0,18,0"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Viewbox>
