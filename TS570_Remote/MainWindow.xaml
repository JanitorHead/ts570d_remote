                                               Fill="#FFFF9200" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </Grid>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" Margin="0">
                            <TextBlock Text="IF SHIFT  ◉  SQL" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                            <Grid HorizontalAlignment="Center" Width="72" Height="72">
                                <Grid RenderTransformOrigin="0.5,0.5"
                                      MouseWheel="IfSqlOuterKnob_MouseWheel" PreviewMouseWheel="IfSqlOuterKnob_MouseWheel"
                                      MouseLeftButtonDown="IfSqlOuterKnob_MouseLeftButtonDown" MouseMove="IfSqlOuterKnob_MouseMove" MouseLeftButtonUp="IfSqlOuterKnob_MouseLeftButtonUp">
                                    <Grid.RenderTransform>
                                        <RotateTransform x:Name="rtIfSqlOuter" Angle="0"/>
                                    </Grid.RenderTransform>
                                    <Ellipse StrokeThickness="2">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#FF444452" Offset="0.45"/>
                                                <GradientStop Color="#FF20202E" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                        <Ellipse.Stroke>
                                            <StaticResource ResourceKey="KnobRim"/>
                                        </Ellipse.Stroke>
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.7"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <Rectangle Width="3.5" Height="15" RadiusX="1.5" RadiusY="1.5" Fill="#FFFF9200" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,5,0,0">
                                        <Rectangle.Effect>
                                            <DropShadowEffect Color="#FFFF9200" BlurRadius="4" ShadowDepth="0" Opacity="0.65"/>
                                        </Rectangle.Effect>
                                    </Rectangle>
                                </Grid>
                                <Grid Width="40" Height="40" RenderTransformOrigin="0.5,0.5"
                                      MouseWheel="IfSqlInnerKnob_MouseWheel" PreviewMouseWheel="IfSqlInnerKnob_MouseWheel"
                                      MouseLeftButtonDown="IfSqlInnerKnob_MouseLeftButtonDown" MouseMove="IfSqlInnerKnob_MouseMove" MouseLeftButtonUp="IfSqlInnerKnob_MouseLeftButtonUp">
                                    <Grid.RenderTransform>
                                        <RotateTransform x:Name="rtIfSqlInner" Angle="0"/>
                                    </Grid.RenderTransform>
                                    <Ellipse StrokeThickness="1.5">
                                        <Ellipse.Fill>
                                            <StaticResource ResourceKey="KnobInner"/>
                                        </Ellipse.Fill>
                                        <Ellipse.Stroke>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#FF6A6A74" Offset="0"/>
                                                <GradientStop Color="#FF2A2A36" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Ellipse.Stroke>
                                    </Ellipse>
                                    <Rectangle Width="2.4" Height="9" RadiusX="1.2" RadiusY="1.2" Fill="#FFFF9200" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,2.5,0,0"/>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- ══ ROW 3 - STATUS BAR ══════════════════════════════════════ -->
                <Border Grid.Row="3" CornerRadius="0,0,6,6" BorderThickness="0,1,0,0" Padding="12,0">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#FF30303C"/>
                    </Border.BorderBrush>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FF181824" Offset="0"/>
                            <GradientStop Color="#FF10101C" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="txtStatusLeft"
