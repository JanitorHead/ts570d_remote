                        </StackPanel>
                    </StackPanel>

                    <!-- COL 3: MODES -->
                    <StackPanel Grid.Column="3" Orientation="Vertical" Margin="0,0,0,0" VerticalAlignment="Top">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,2,0,4">
                            <Button x:Name="btnLsbUsb" Style="{StaticResource LightRoundMiniBtn}" Width="30" Height="30" Margin="0,2" Click="btnLsbUsb_Click">
                                <Button.Content>
                                    <TextBlock Text="LSB&#10;USB" TextAlignment="Center" FontSize="7" FontWeight="Bold" LineHeight="7.5"/>
                                </Button.Content>
                            </Button>
                            <Button x:Name="btnCwFsk" Style="{StaticResource LightRoundMiniBtn}" Width="30" Height="30" Margin="0,2" Click="btnCwFsk_Click">
                                <Button.Content>
                                    <TextBlock Text="CW&#10;FSK" TextAlignment="Center" FontSize="7" FontWeight="Bold" LineHeight="7.5"/>
                                </Button.Content>
                            </Button>
                            <Button x:Name="btnFmAm" Style="{StaticResource LightRoundMiniBtn}" Width="30" Height="30" Margin="0,2" Click="btnFmAm_Click">
                                <Button.Content>
                                    <TextBlock Text="FM&#10;AM" TextAlignment="Center" FontSize="7" FontWeight="Bold" LineHeight="7.5"/>
                                </Button.Content>
                            </Button>
                        </StackPanel>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="MENU" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.2" FontWeight="Bold"
                                           HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                <Button x:Name="btnMenu" Style="{StaticResource RoundMiniBtn}" Width="30" Height="30" Click="btnMenu_Click"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="1MHz" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.2" FontWeight="Bold"
                                           HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                <Button x:Name="btn1MHz" Style="{StaticResource RoundMiniBtn}" Width="30" Height="30" Click="btn1MHz_Click"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- COL 4: KNOB VFO -->
                    <StackPanel Grid.Column="4" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-10,0,0">
                        <!-- Internal controls kept for compatibility -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0" Visibility="Collapsed">
                            <Button x:Name="btnStepDown" Content="&lt;" Margin="2,2" Width="30" Height="26" FontSize="15" FontWeight="Bold" Click="btnStepDown_Click"/>
                            <TextBlock x:Name="txtTuneStep" Text="1 kHz" FontFamily="Consolas" FontSize="10.5" Foreground="#FFAAAABC" VerticalAlignment="Center" Margin="4,0" MinWidth="48" TextAlignment="Center"/>
                            <Button x:Name="btnStepUp" Content="&gt;" Margin="2,2" Width="30" Height="26" FontSize="15" FontWeight="Bold" Click="btnStepUp_Click"/>
                        </StackPanel>
                        <Grid Width="200" Height="200"
                              MouseWheel="VfoMainKnob_MouseWheel" PreviewMouseWheel="VfoMainKnob_MouseWheel"
                              MouseLeftButtonDown="VfoMainKnob_MouseLeftButtonDown" MouseMove="VfoMainKnob_MouseMove" MouseLeftButtonUp="VfoMainKnob_MouseLeftButtonUp">
                            <Ellipse StrokeThickness="4.5">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#FF3A3A46" Offset="0.55"/>
                                        <GradientStop Color="#FF262632" Offset="0.76"/>
                                        <GradientStop Color="#FF1A1A24" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Stroke>
                                    <LinearGradientBrush StartPoint="0.1,0" EndPoint="0.9,1">
                                        <GradientStop Color="#FF878792" Offset="0"/>
                                        <GradientStop Color="#FF2A2A36" Offset="0.55"/>
                                        <GradientStop Color="#FF6C6C78" Offset="1"/>
                                    </LinearGradientBrush>
                                </Ellipse.Stroke>
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="5" Opacity="0.88"/>
                                </Ellipse.Effect>
                            </Ellipse>

                            <Grid RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <RotateTransform x:Name="rtVfoMain" Angle="0"/>
                                </Grid.RenderTransform>
                                <Ellipse Width="170" Height="170" StrokeThickness="2.2">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush Center="0.38,0.34" GradientOrigin="0.34,0.28">
                                            <GradientStop Color="#FF5A5A66" Offset="0"/>
                                            <GradientStop Color="#FF3E3E4A" Offset="0.58"/>
                                            <GradientStop Color="#FF242430" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                    <Ellipse.Stroke>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF6A6A74" Offset="0"/>
                                            <GradientStop Color="#FF181820" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Ellipse.Stroke>
                                </Ellipse>

                                <!-- Finger indentation (no linear marker) -->
                                <Ellipse Width="54" Height="54" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="46,54,0,0">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush Center="0.28,0.28" GradientOrigin="0.25,0.25">
                                            <GradientStop Color="#FF6D6D78" Offset="0"/>
                                            <GradientStop Color="#FF444451" Offset="0.55"/>
                                            <GradientStop Color="#FF2A2A36" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                    <Ellipse.Stroke>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#8050505A" Offset="0"/>
                                            <GradientStop Color="#4016161E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Ellipse.Stroke>
                                </Ellipse>

                                <Ellipse Width="170" Height="170" StrokeThickness="0.6" Stroke="#22FFFFFF" Fill="Transparent"/>
                            </Grid>
                        </Grid>
                    </StackPanel>

                    <!-- COL 5: DOWN/UP + QUICK MEMO + SPLIT BUTTONS -->
                    <StackPanel Grid.Column="5" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,-10,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="3,0">
                                <TextBlock Text="DOWN" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                <Button x:Name="btnFreqDown" Style="{StaticResource LightRoundVfoBtn}" Width="42" Height="42" Click="btnFreqDown_Click">
                                    <Button.Content>
                                        <Grid>
                                            <Border Width="24" Height="4" CornerRadius="2"
                                                   Background="#33FFFFFF"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="-2,-2,0,0"/>
                                            <Border Width="24" Height="4" CornerRadius="2"
                                                   Background="#B3000000"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="2,2,0,0"/>
                                            <Border Width="24" Height="4" CornerRadius="2"
                                                   Background="#FF09090F"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button.Content>
                                </Button>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="3,0">
                                <TextBlock Text="UP" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                <Button x:Name="btnFreqUp" Style="{StaticResource LightRoundVfoBtn}" Width="42" Height="42" Click="btnFreqUp_Click">
                                    <Button.Content>
                                        <Grid>
                                            <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-2,-2,0,0">
                                                <Border Width="24" Height="4" CornerRadius="2" Background="#33FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Border Width="4" Height="24" CornerRadius="2" Background="#33FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,2,0,0">
                                                <Border Width="24" Height="4" CornerRadius="2" Background="#B3000000" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Border Width="4" Height="24" CornerRadius="2" Background="#B3000000" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border Width="24" Height="4" CornerRadius="2" Background="#FF09090F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Border Width="4" Height="24" CornerRadius="2" Background="#FF09090F" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Grid>
                                    </Button.Content>
                                </Button>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="2,0,1,0">
                                <TextBlock Text="MR" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                <Button x:Name="btnQmMR" Style="{StaticResource RoundVfoBtn}" Width="34" Height="34" FontSize="8" Content="" Click="btnQmMR_Click"/>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="2,0,2,0">
                                <TextBlock Text="" FontSize="8" Margin="0,0,0,2"/>
                                <Button x:Name="btnQmMIn" Style="{StaticResource RoundVfoBtn}" Width="34" Height="34" FontSize="7.5" Content="" Click="btnQmMIn_Click"/>
                                <TextBlock Text="M.IN" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        <!-- Kept for compatibility -->
                        <StackPanel Orientation="Horizontal" Visibility="Collapsed">
                            <Button x:Name="btnQmPlus" Content="+" Click="btnQmPlus_Click"/>
                            <Button x:Name="btnQmMinus" Content="-" Click="btnQmMinus_Click"/>
                        </StackPanel>
                        <UniformGrid Rows="1" Columns="4" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <Button x:Name="btnSplit" Content="SPLIT" Style="{StaticResource LightRoundVfoBtn}" Margin="2,2" Click="btnSplit_Click"/>
                            <Button x:Name="btnTfSet" Content="TF-set" Style="{StaticResource LightRoundVfoBtn}" Margin="2,2" Click="btnTfSet_Click"/>
                            <Button x:Name="btnAB" Content="A / B" Style="{StaticResource LightRoundVfoBtn}" Margin="2,2" Click="btnAB_Click"/>
                            <Button x:Name="btnRit" Content="RIT" Style="{StaticResource LightRoundVfoBtn}" Margin="2,2" Click="btnRit_Click"/>
                        </UniformGrid>
                        <UniformGrid Rows="1" Columns="4" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <Button x:Name="btnMV" Content="M / V" Style="{StaticResource LightRoundVfoBtn}" Margin="2,2" Click="btnMV_Click"/>
                            <Button x:Name="btnAeqB" Content="A = B" Style="{StaticResource LightRoundVfoBtn}" Margin="2,2" Click="btnAeqB_Click"/>
                            <Button x:Name="btnCLS" Content="CLS" Style="{StaticResource LightRoundVfoBtn}" Margin="2,2" Click="btnCLS_Click"/>
                            <Button x:Name="btnXit" Content="XIT" Style="{StaticResource LightRoundVfoBtn}" Margin="2,2" Click="btnXit_Click"/>
                        </UniformGrid>
                        <UniformGrid Rows="1" Columns="3" HorizontalAlignment="Center">
                            <Button x:Name="btnScan" Content="SCAN" Style="{StaticResource PillBtn}" Margin="0,2,4,2" FontSize="9.5" Click="btnScan_Click"/>
                            <Button x:Name="btnMVfo" Content="M&gt;VFO" Style="{StaticResource PillBtn}" Margin="4,2,4,2" FontSize="9.5" Click="btnMVfo_Click"/>
                            <Button x:Name="btnMIn" Content="M.IN" Style="{StaticResource PillBtn}" Margin="4,2,0,2" FontSize="9.5" Click="btnMIn_Click"/>
                        </UniformGrid>
                    </StackPanel>

                    <!-- COL 6: 2x2 POTENTIOMETERS -->
                    <Grid Grid.Column="6" Margin="2,4,2,4" Width="220" HorizontalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Margin="0">
                            <TextBlock Text="RIT / XIT" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="8.2" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                            <Grid HorizontalAlignment="Center" Width="63" Height="63" Margin="0,0,0,4"
                                  MouseWheel="RitXitKnob_MouseWheel" PreviewMouseWheel="RitXitKnob_MouseWheel"
                                  MouseLeftButtonDown="RitXitKnob_MouseLeftButtonDown" MouseMove="RitXitKnob_MouseMove" MouseLeftButtonUp="RitXitKnob_MouseLeftButtonUp">
                                <Grid RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <RotateTransform x:Name="rtRitXit" Angle="0"/>
                                    </Grid.RenderTransform>
                                    <Ellipse StrokeThickness="2">
                                        <Ellipse.Fill><StaticResource ResourceKey="KnobFace"/></Ellipse.Fill>
                                        <Ellipse.Stroke><StaticResource ResourceKey="KnobRim"/></Ellipse.Stroke>
                                        <Ellipse.Effect><DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.7"/></Ellipse.Effect>
                                    </Ellipse>
                                    <Rectangle Width="2.6" Height="11" RadiusX="1.2" RadiusY="1.2"
                                               Fill="#FFF0F0F4" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </Grid>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Margin="0">
                            <TextBlock Text="AF  ◉  RF" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="8.2" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                            <Grid HorizontalAlignment="Center" Width="72" Height="72" Margin="0,0,0,4">
                                <Grid RenderTransformOrigin="0.5,0.5"
                                      MouseWheel="AfRfOuterKnob_MouseWheel" PreviewMouseWheel="AfRfOuterKnob_MouseWheel"
                                      MouseLeftButtonDown="AfRfOuterKnob_MouseLeftButtonDown" MouseMove="AfRfOuterKnob_MouseMove" MouseLeftButtonUp="AfRfOuterKnob_MouseLeftButtonUp">
                                    <Grid.RenderTransform>
                                        <RotateTransform x:Name="rtAfRfOuter" Angle="0"/>
                                    </Grid.RenderTransform>
                                    <Ellipse StrokeThickness="2">
                                        <Ellipse.Fill><RadialGradientBrush><GradientStop Color="#FF444452" Offset="0.45"/><GradientStop Color="#FF20202E" Offset="1"/></RadialGradientBrush></Ellipse.Fill>
                                        <Ellipse.Stroke><StaticResource ResourceKey="KnobRim"/></Ellipse.Stroke>
                                        <Ellipse.Effect><DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.7"/></Ellipse.Effect>
                                    </Ellipse>
                                    <Rectangle Width="3.5" Height="15" RadiusX="1.5" RadiusY="1.5" Fill="#FFFF9200" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </Grid>
                                <Grid Width="40" Height="40" RenderTransformOrigin="0.5,0.5"
                                      MouseWheel="AfRfInnerKnob_MouseWheel" PreviewMouseWheel="AfRfInnerKnob_MouseWheel"
                                      MouseLeftButtonDown="AfRfInnerKnob_MouseLeftButtonDown" MouseMove="AfRfInnerKnob_MouseMove" MouseLeftButtonUp="AfRfInnerKnob_MouseLeftButtonUp">
                                    <Grid.RenderTransform>
                                        <RotateTransform x:Name="rtAfRfInner" Angle="0"/>
                                    </Grid.RenderTransform>
                                    <Ellipse StrokeThickness="1.5"><Ellipse.Fill><StaticResource ResourceKey="KnobInner"/></Ellipse.Fill><Ellipse.Stroke><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#FF6A6A74" Offset="0"/><GradientStop Color="#FF2A2A36" Offset="1"/></LinearGradientBrush></Ellipse.Stroke></Ellipse>
                                    <Rectangle Width="2.4" Height="9" RadiusX="1.2" RadiusY="1.2" Fill="#FFFF9200" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,2.5,0,0"/>
                                </Grid>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" Margin="0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,3">
                                <Border Background="#FFFF9200" CornerRadius="1" Padding="3,0,3,0">
                                    <TextBlock Text="MULTI" Foreground="#FF2A2A30" FontFamily="Consolas" FontSize="7.8" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text=" CH" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="8.2" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Grid HorizontalAlignment="Center" Width="63" Height="63"
                                  MouseWheel="MultiChKnob_MouseWheel" PreviewMouseWheel="MultiChKnob_MouseWheel"
                                  MouseLeftButtonDown="MultiChKnob_MouseLeftButtonDown" MouseMove="MultiChKnob_MouseMove" MouseLeftButtonUp="MultiChKnob_MouseLeftButtonUp">
                                <Grid RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <RotateTransform x:Name="rtMultiCh" Angle="0"/>
                                    </Grid.RenderTransform>
                                    <Ellipse StrokeThickness="2">
                                        <Ellipse.Fill><StaticResource ResourceKey="KnobFace"/></Ellipse.Fill>
                                        <Ellipse.Stroke><StaticResource ResourceKey="KnobRim"/></Ellipse.Stroke>
                                        <Ellipse.Effect><DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.7"/></Ellipse.Effect>
                                    </Ellipse>
                                    <Rectangle Width="2.6" Height="11" RadiusX="1.2" RadiusY="1.2"
                                               Fill="#FFFF9200" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </Grid>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" Margin="0">
                            <TextBlock Text="IF SHIFT  ◉  SQL" Foreground="{StaticResource UiTextWhite}" FontFamily="Consolas" FontSize="7.8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                            <Grid HorizontalAlignment="Center" Width="72" Height="72">
                                <Grid RenderTransformOrigin="0.5,0.5"
                                      MouseWheel="IfSqlOuterKnob_MouseWheel" PreviewMouseWheel="IfSqlOuterKnob_MouseWheel"
                                      MouseLeftButtonDown="IfSqlOuterKnob_MouseLeftButtonDown" MouseMove="IfSqlOuterKnob_MouseMove" MouseLeftButtonUp="IfSqlOuterKnob_MouseLeftButtonUp">
                                    <Grid.RenderTransform>
                                        <RotateTransform x:Name="rtIfSqlOuter" Angle="0"/>
                                    </Grid.RenderTransform>
                                    <Ellipse StrokeThickness="2">
                                        <Ellipse.Fill><RadialGradientBrush><GradientStop Color="#FF444452" Offset="0.45"/><GradientStop Color="#FF20202E" Offset="1"/></RadialGradientBrush></Ellipse.Fill>
                                        <Ellipse.Stroke><StaticResource ResourceKey="KnobRim"/></Ellipse.Stroke>
                                        <Ellipse.Effect><DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.7"/></Ellipse.Effect>
                                    </Ellipse>
                                    <Rectangle Width="3.5" Height="15" RadiusX="1.5" RadiusY="1.5" Fill="#FFFF9200" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,5,0,0">
                                        <Rectangle.Effect>
                                            <DropShadowEffect Color="#FFFF9200" BlurRadius="4" ShadowDepth="0" Opacity="0.65"/>
                                        </Rectangle.Effect>
                                    </Rectangle>
                                </Grid>
                                <Grid Width="40" Height="40" RenderTransformOrigin="0.5,0.5"
                                      MouseWheel="IfSqlInnerKnob_MouseWheel" PreviewMouseWheel="IfSqlInnerKnob_MouseWheel"
                                      MouseLeftButtonDown="IfSqlInnerKnob_MouseLeftButtonDown" MouseMove="IfSqlInnerKnob_MouseMove" MouseLeftButtonUp="IfSqlInnerKnob_MouseLeftButtonUp">
                                    <Grid.RenderTransform>
                                        <RotateTransform x:Name="rtIfSqlInner" Angle="0"/>
                                    </Grid.RenderTransform>
                                    <Ellipse StrokeThickness="1.5"><Ellipse.Fill><StaticResource ResourceKey="KnobInner"/></Ellipse.Fill><Ellipse.Stroke><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#FF6A6A74" Offset="0"/><GradientStop Color="#FF2A2A36" Offset="1"/></LinearGradientBrush></Ellipse.Stroke></Ellipse>
                                    <Rectangle Width="2.4" Height="9" RadiusX="1.2" RadiusY="1.2" Fill="#FFFF9200" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,2.5,0,0"/>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- ══ ROW 3 - STATUS BAR ══════════════════════════════════════ -->
                <Border Grid.Row="3" CornerRadius="0,0,6,6" BorderThickness="0,1,0,0" Padding="12,0">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#FF30303C"/>
                    </Border.BorderBrush>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FF181824" Offset="0"/>
                            <GradientStop Color="#FF10101C" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="txtStatusLeft"
                               Text="OmniRig - waiting for connection..."
                               FontFamily="Consolas" FontSize="8.5"
                               Foreground="#FF646472" Margin="0,0,18,0"/>
                        <TextBlock Text="CAT: " FontFamily="Consolas" FontSize="8.5" Foreground="#FF646472"/>
                        <Ellipse x:Name="ledCatGreen" Style="{StaticResource LedGreen}" Margin="3,0,3,0" Visibility="Hidden"/>
                        <Ellipse x:Name="ledCatAmber" Style="{StaticResource LedAmber}"  Margin="3,0,3,0"/>
                        <TextBlock x:Name="txtStatusRight"
                               Text="  ---"
                               FontFamily="Consolas" FontSize="8.5"
                               Foreground="#FF646472" Margin="0,0,18,0"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Viewbox>
</Window>
